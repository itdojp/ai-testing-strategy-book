{
  "schema": "statistical-decision-contract/v1",
  "policy": {
    "version": "1.0.0",
    "policy_locked_at": "2026-07-01",
    "analysis_unit": "pull_request",
    "metric": "review_rework_minutes",
    "design": "independent_two_group_welch",
    "direction": "lower_is_better",
    "minimum_sample_per_group": 30,
    "practical_threshold": 0.5,
    "confidence_level": 0.95,
    "alpha": 0.05,
    "p_value_role": "auxiliary_only",
    "multiple_testing": {
      "family_id": "release-primary-quality-metrics",
      "method": "holm",
      "planned_comparisons": 3,
      "planned_metrics": [
        "review_rework_minutes",
        "escaped_defect_rate",
        "change_failure_rate"
      ]
    },
    "repeated_looks": {
      "method": "fixed_horizon",
      "maximum_looks": 1
    }
  },
  "cases": [
    {
      "id": "no-effect",
      "observed_at": "2026-07-15",
      "baseline": {"n": 60, "mean": 10.0, "sd": 1.0},
      "candidate": {"n": 60, "mean": 10.0, "sd": 1.0},
      "expected_decision": "no_practical_improvement"
    },
    {
      "id": "small-but-statistically-significant",
      "observed_at": "2026-07-15",
      "baseline": {"n": 10000, "mean": 10.0, "sd": 1.0},
      "candidate": {"n": 10000, "mean": 9.9, "sd": 1.0},
      "expected_decision": "no_practical_improvement"
    },
    {
      "id": "threshold-crossing-interval",
      "observed_at": "2026-07-15",
      "baseline": {"n": 60, "mean": 10.0, "sd": 1.0},
      "candidate": {"n": 60, "mean": 9.4, "sd": 2.0},
      "expected_decision": "inconclusive"
    },
    {
      "id": "large-effect",
      "observed_at": "2026-07-15",
      "baseline": {"n": 120, "mean": 10.0, "sd": 1.5},
      "candidate": {"n": 120, "mean": 8.0, "sd": 1.5},
      "expected_decision": "practical_improvement"
    }
  ],
  "multiple_testing_example": [
    {
      "metric": "review_rework_minutes",
      "raw_p_value": 0.01,
      "expected_adjusted_p_value": 0.03
    },
    {
      "metric": "escaped_defect_rate",
      "raw_p_value": 0.03,
      "expected_adjusted_p_value": 0.06
    },
    {
      "metric": "change_failure_rate",
      "raw_p_value": 0.04,
      "expected_adjusted_p_value": 0.06
    }
  ]
}
