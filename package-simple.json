{
  "name": "ai-testing-strategy-book",
  "version": "1.0.0",
  "description": "品質保証の新パラダイム - AI生成コードに対応した実践的テスト手法",
  "author": "ITDO Inc.",
  "license": "CC-BY-NC-SA-4.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "setup": "node easy-setup.js",
    "build": "node scripts/build-simple.js",
    "build:full": "node scripts/build.js",
    "preview": "npm run build && npx http-server docs -p 8080 --silent",
    "clean": "rm -rf docs output temp",
    "lint:light": "markdownlint 'src/**/*.md' --ignore node_modules",
    "test:light": "npm run lint:light && npm run build",
    "help": "echo 'Available commands:\n  npm run setup - Interactive setup\n  npm run build - Build the book\n  npm run preview - Local preview'"
  },
  "dependencies": {
    "fs-extra": "^11.3.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "markdownlint-cli": "^0.49.0"
  },
  "optionalDependencies": {
    "puppeteer": "^25.3.0",
    "sharp": "^0.34.5"
  },
  "keywords": [
    "book",
    "publishing",
    "markdown",
    "github-pages",
    "template",
    "easy-setup"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itdojp/ai-testing-strategy-book.git"
  },
  "bugs": {
    "url": "https://github.com/itdojp/ai-testing-strategy-book/issues"
  },
  "homepage": "https://itdojp.github.io/ai-testing-strategy-book/"
}
